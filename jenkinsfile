pipeline {
    agent any

    environment {
        IMAGE_NAME = "my-app"
        TAG = "latest"
    }

    stages {

        stage('Clone Repo') {
            steps {
                git 'https://github.com/your-username/your-repo.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    sh "docker build -t $IMAGE_NAME:$TAG ."
                }
            }
        }

        stage('Run Container (optional)') {
            steps {
                script {
                    sh "docker run -d -p 5000:5000 $IMAGE_NAME:$TAG"
                }
            }
        }
    }
}
